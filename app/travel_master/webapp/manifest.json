{
  "_version": "1.82.0",
  "sap.app": {
    "id": "com.demo.travelmaster",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.4",
      "toolsId": "491ace6b-501a-4589-a7db-6e025b8f41bc"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/travel-request/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.demo.travelmaster.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "TravelRequestList",
          "target": "TravelRequestList"
        },
        {
          "pattern": "TravelRequest({key}):?query:",
          "name": "TravelRequestObjectPage",
          "target": "TravelRequestObjectPage"
        },
        {
          "pattern": "TravelRequest({key})/expenses({key2}):?query:",
          "name": "TravelExpensesObjectPage",
          "target": "TravelExpensesObjectPage"
        }
      ],
      "targets": {
        "TravelRequestList": {
          "type": "Component",
          "id": "TravelRequestList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/TravelRequest",
              "variantManagement": "Page",
              "navigation": {
                "TravelRequest": {
                  "detail": {
                    "route": "TravelRequestObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataField::purpose": {
                      "width": "7rem",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              },
              "defaultTemplateAnnotationPath": "com.sap.vocabularies.UI.v1.SelectionPresentationVariant#tableView"
            }
          }
        },
        "TravelRequestObjectPage": {
          "type": "Component",
          "id": "TravelRequestObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/TravelRequest",
              "navigation": {
                "expenses": {
                  "detail": {
                    "route": "TravelExpensesObjectPage"
                  }
                }
              }
            }
          }
        },
        "TravelExpensesObjectPage": {
          "type": "Component",
          "id": "TravelExpensesObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/TravelRequest/expenses"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
