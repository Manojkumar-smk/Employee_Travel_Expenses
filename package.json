{
  "name": "Employee_Travel_Expenses",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "express": "^4",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-employee_master": "cds watch --open com.demo.employeemaster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project_master": "cds watch --open com.demo.projectmaster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-travel_master": "cds watch --open com.demo.travelmaster/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-approval_master": "cds watch --open com.demo.approvalmaster/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/employee_master",
    "app/project_master",
    "app/travel_master",
    "app/approval_master"
  ],
  "cds": {
  "requires": {
    "[production]": {
      "db": "hana",
      "auth": "xsuaa"
    },
    "auth": {
      "[development]": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "roles": ["Admin"],
            "attr": { "empId": ["E-20609"] }
          },
          "employee": {
            "password": "employee",
            "roles": ["Employee"],
            "attr": { "empId": ["E-20610", "E-20611", "E-20613"] }
          },
          "approver": {
            "password": "approver",
            "roles": ["Approver"],
            "attr": { "empId": ["E-20612"] }
          }
        }
      }
    }
  }
}
}
